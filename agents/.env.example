# .env example — copy this to agents/.env and fill in your keys
LLM_PROVIDER=mock

OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
GROK_API_KEY=your_grok_api_key
SARVAM_API_KEY=your_sarvam_api_key

# Agent ports
AGENT_A_PORT=3004
AGENT_B_PORT=3005

AGENT_A_URL=http://localhost:3004
AGENT_B_URL=http://localhost:3005
